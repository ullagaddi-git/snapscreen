{
  "name": "snapscreen",
  "version": "0.3.0",
  "description": "Record the screen you mean to record. Nothing else.",
  "main": "./out/main/main.js",
  "scripts": {
    "dev": "node node_modules/electron-vite/bin/electron-vite.js dev",
    "build": "node node_modules/electron-vite/bin/electron-vite.js build",
    "preview": "node node_modules/electron-vite/bin/electron-vite.js preview",
    "lint": "node node_modules/eslint/bin/eslint.js . --ext .ts,.tsx",
    "dist": "node node_modules/electron-vite/bin/electron-vite.js build && node node_modules/electron-builder/cli.js --config electron-builder.config.js"
  },
  "keywords": [
    "screen-recorder",
    "electron",
    "windows"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "dayjs": "^1.11.20",
    "electron-store": "^11.0.2",
    "electron-vite": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "typescript": "^6.0.2"
  }
}
